library(kmed)
library(mclust)
library(dplyr)
adjusted_score <- function(y_pred, y_true, metric) {
# Obtener etiquetas únicas y todas sus permutaciones
unique_labels   <- unique(y_pred)
perms_list      <- permutations(unique_labels)   # ver nota abajo
best_score  <- -Inf
best_labels <- NULL
for (i in seq_len(nrow(perms_list))) {
perm <- perms_list[i, ]
# Crear diccionario de mapeo: label original → label permutado
perm_dict <- setNames(perm, unique_labels)
# Aplicar la permutación a y_pred
permuted_labels <- perm_dict[as.character(y_pred)]
# Calcular métrica
score <- metric(y_true, permuted_labels)
if (score > best_score) {
best_score  <- score
best_labels <- permuted_labels
}
}
return(list(
adj_score          = best_score,
adj_cluster_labels = unname(best_labels)
))
}
permutations <- function(x) {
if (length(x) == 1) return(matrix(x))
do.call(rbind, lapply(seq_along(x), function(i) {
cbind(x[i], permutations(x[-i]))
}))
}
# Accuracy (default en Python)
accuracy   <- function(y_true, y_pred) mean(y_true == y_pred)
# 1. Definir la ruta (ojo: en R usamos / o \\ para rutas en Windows)
ruta_folder <- "../../../data/skm_budiaji/simulations_data"
# 2. Listar los archivos con su path completo para poder leerlos
rutas_completas <- list.files(path = ruta_folder, pattern = "\\.csv$", full.names = TRUE)
# 3. Extraer solo el nombre del archivo (sin la extensión .csv) para usarlo como "key"
nombres_archivos <- tools::file_path_sans_ext(basename(rutas_completas))
# 4. Leer todos los archivos en una lista
lista_csvs <- lapply(rutas_completas, read.csv)
# 5. Asignar los nombres a la lista (aquí es donde se vuelve un "diccionario")
names(lista_csvs) <- nombres_archivos
