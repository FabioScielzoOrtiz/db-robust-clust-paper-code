accuracy <- function(y_true, y_pred) {
mean(as.integer(y_true) == as.integer(y_pred))  # ← tipos consistentes
}
# ── Inicializar contenedor de resultados ──────────────
results <- data.frame(
data_id      = character(),
iteration    = integer(),
